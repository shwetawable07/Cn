Q2 (B) Program – Even Parity

#include <stdio.h>
#include <string.h>
int main() {
    char data[100];
    int count = 0;
    printf("Enter binary data: ");
    scanf("%s", data);
    for(int i = 0; i < strlen(data); i++) {
        if(data[i] == '1') count++;
    }
    if(count % 2 == 0)
        printf("Even parity bit: 0\n");
    else
        printf("Even parity bit: 1\n");
    return 0;
}











































