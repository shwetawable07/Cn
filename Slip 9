Q2 (B) – Option 1: Program to Determine IP Class (C)

#include <stdio.h>
int main() {
    int first_octet;
    printf("Enter first octet of IP address: ");
    scanf("%d", &first_octet);
    if (first_octet >= 1 && first_octet <= 126)
        printf("Class A\n");
    else if (first_octet >= 128 && first_octet <= 191)
        printf("Class B\n");
    else if (first_octet >= 192 && first_octet <= 223)
        printf("Class C\n");
    else if (first_octet >= 224 && first_octet <= 239)
        printf("Class D (Multicast)\n");
    else if (first_octet >= 240 && first_octet <= 255)
        printf("Class E (Experimental)\n");
    else
        printf("Invalid IP\n");
    return 0;
}















