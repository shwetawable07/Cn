Q2 (B) Character Count Framing (C Program)

#include <stdio.h>
#include <string.h>
int main() {
    char data[100];
    int len;
    printf("Enter data: ");
    scanf("%s", data);
    len = strlen(data);
    printf("Framed data (Character Count Method):\n");
    printf("%d%s\n", len + 1, data);
    return 0;
}






















