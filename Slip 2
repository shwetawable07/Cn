Q2 (B) Simple Hash Simulation (C Program)

#include <stdio.h>
int main() {
    int hash[10] = {0}, key, index;
    for(int i=0; i<5; i++) {
        printf("Enter value: ");
        scanf("%d", &key);
        index = key % 10;
        hash[index] = key;
    }

    printf("Hash Table:\n");
    for(int i=0; i<10; i++) {
        printf("%d -> %d\n", i, hash[i]);
    }
    return 0;
}























