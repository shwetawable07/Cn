#include <stdio.h>
#include <string.h>
void charStuffing(char data[]) {
    printf("Character Stuffing Output: DLE STX ");
    for(int i=0; i<strlen(data); i++) {
        if(data[i]=='D')
            printf("DLE ");
        printf("%c ", data[i]);
    }
    printf("DLE ETX\n");
}
void bitStuffing(char data[]) {
    int count=0;
    printf("Bit Stuffing Output: ");
    for(int i=0; i<strlen(data); i++) {
        printf("%c", data[i]);
        if(data[i]=='1') {
            count++;
            if(count==5) {
                printf("0");
                count=0;
            }
        } else {
            count=0;
        }
    }
}
int main() {
    char data[50];
    printf("Enter data: ");
    scanf("%s", data);

    charStuffing(data);
    bitStuffing(data);
    return 0;
}
