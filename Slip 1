Subnetting:

Subnetting is the process of dividing a large network into smaller networks (subnets) to:

Improve performance
Increase security
Use IP addresses efficiently


#include<stdio.h>
#include<math.h>
int main()
{
int ip1,ip2,ip3,ip4;
int prefix, host_bits, hosts;
printf("Enter IP Address (x.x.x.x): ");
scanf("%d.%d.%d.%d",&ip1,&ip2,&ip3,&ip4);
printf("Enter CIDR prefix: ");
scanf("%d",&prefix);
host_bits = 32 - prefix;
hosts = pow(2, host_bits) - 2;
printf("\nIP Address : %d.%d.%d.%d/%d\n",ip1,ip2,ip3,ip4,prefix);
printf("Network ID : %d.%d.%d.0\n",ip1,ip2,ip3);
printf("Broadcast Address : %d.%d.%d.255\n",ip1,ip2,ip3);
printf("Usable Hosts : %d\n",hosts);
return 0;
}


