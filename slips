Q.Write a program to verify the configuration using show running- config and ping commands.

#include <stdio.h>
#include <stdlib.h> 
int main() 
{
printf("--- Network Configuration Verification Program ---\n\n");
printf("Step 1: Fetching current running configuration...\n");
int config_status = system("show running-config");
if (config_status == -1)
{
printf("Error: Could not execute configuration command.\n");
}
else
{
printf("\nConfiguration fetch completed with status: %d\n", config_status);
}
printf("\n--------------------------------------------------\n");
char target_ip[] = "8.8.8.8";
printf("Step 2: Pinging %s to verify connectivity...\n", target_ip);
char ping_cmd[50];
sprintf(ping_cmd, "ping -c 4 %s", target_ip);
int ping_status = system(ping_cmd);
if (ping_status == 0) 
{
printf("\nResult: SUCCESS - Target %s is reachable.\n", target_ip);
} 
else
{
printf("\nResult: FAILED - Target %s is unreachable.\n", target_ip);
}
return 0;
}



Q.write a c program to implement static routing simulation

#include <stdio.h>
#include <string.h>
struct Route
{
char destNetwork[20];
char nextHop[20];
int interface;
}; 
void routePacket(struct Route table[], int tableSize, char*destination)
{
int i; 
int found = 0;
for (i = 0; i < tableSize; i++)
{
if (strcmp(table[i].destNetwork, destination) == 0)
{
printf("Packet destined for %s -> Forward to Next Hop: %s via Interface %d\n", destination, table[i].nextHop, table[i].interface); 
found = 1;
break;
}
}
if (!found) 
{
printf("Packet destined for %s -> No route found. Packet dropped.\n",destination);
}
}
int main() 
{
struct Route routingTable[3] = {
{"192.168.2.0", "10.0.0.2", 1}, 
{"192.168.3.0", "10.0.0.2", 1},
{"10.0.0.0", "Direct", 0}
}; 
printf("--- Static Routing Simulation (Router A) ---\n");
routePacket(routingTable, 3, "192.168.2.0");
routePacket(routingTable, 3, "192.168.3.0");
routePacket(routingTable, 3, "192.168.4.0"); 
return 0;
}



Q.Write a Program to convert plain message to cipher message

#include <stdio.h>
#include <string.h>
int main()
{ 
char message[100]; 
int key, i;
printf("Enter a message to encrypt: ");
fgets(message, sizeof(message), stdin);
message[strcspn(message, "\n")] = '\0'; 
printf("Enter key (1-25): ");
scanf("%d", &key);
for(i = 0; message[i] != '\0'; ++i)
{
char ch = message[i];
if(ch >= 'a' && ch <= 'z')
{
ch = (ch - 'a' + key) % 26 + 'a';
}
else if(ch >= 'A' && ch <= 'Z')
{
ch = (ch - 'A' + key) % 26 + 'A';
} 
message[i] = ch; 
}
printf("Cipher message: %s\n", message);
return 0;
}




















































