Q.Write a program to displays a Mesh Topology.

#include <stdio.h> 
int main()
{ 
int n;
printf("Enter number of computers in mesh topology: ");
scanf("%d", &n); 
if (n < 2)
{
printf("Mesh topology requires at least 2 computers.\n");
return 0;
}
printf("\n----- MESH TOPOLOGY -----\n\n");
for (int i = 1; i <= n; i++)
{
printf(" [PC-%d] ", i); 
}
printf("\n\nConnections between computers:\n");
for (int i = 1; i <= n; i++)
{
for (int j = i + 1; j <= n; j++)
{
printf("PC-%d <----> PC-%d\n", i, j);
}
}
printf("\nIn Mesh Topology every computer is connected to every other
computer.\n");
return 0; 
}


Q.Write a program to implement even parity error detection.

#include <stdio.h>
#include <string.h>
int main()
{
char data[20]; 
int i, count = 0; 
printf("Enter binary data: ");
scanf("%s", data);
for(i = 0; i < strlen(data); i++)
{
if(data[i] == '1')
count++;
}
if(count % 2 == 0) 
{
printf("\nParity Bit (Even Parity) = 0");
printf("\nTransmitted Data = %s0\n", data); 
}
else
{
printf("\nParity Bit (Even Parity) = 1");
printf("\nTransmitted Data = %s1\n", data); count++; 
} 
if(count % 2 == 0)
printf("\nNo Error Detected (Even number of 1s)\n"); else
printf("\nError Detected (Odd number of 1s)\n"); return 0;
}


