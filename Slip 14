Q2 (B) Static Routing Simulation (C)

#include <stdio.h>
#define MAX 10
#define INF 999
int main() {
    int n, cost[MAX][MAX];
    int i, j, k;
    printf("Enter number of routers: ");
    scanf("%d", &n);
    printf("\nEnter cost matrix (enter 999 for no direct path):\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &cost[i][j]);
        }
    }
    for(k = 0; k < n; k++) {
        for(i = 0; i < n; i++) {
            for(j = 0; j < n; j++) {
                if(cost[i][j] > cost[i][k] + cost[k][j]) {
                    cost[i][j] = cost[i][k] + cost[k][j];
                }
            }
        }
    }
    printf("\n--- Static Routing Table (Shortest Paths) ---\n");
    for(i = 0; i < n; i++) {
        printf("\nRouter %d:\n", i + 1);
        for(j = 0; j < n; j++) {
            if(i != j) {
                printf("To Router %d -> Cost = %d\n", j + 1, cost[i][j]);
            }
        }
    }

    printf("\n=== Code Execution Successful ===\n");
    return 0;
}









































