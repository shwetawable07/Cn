Q2 - B write a c code to display mesh topology 

#include <stdio.h>
int main()
{
int n;
printf("Enter number of computers in mesh topology: ");
scanf("%d", &n);
if (n < 2)
{
printf("Mesh topology requires at least 2 computers.\n");
return 0;
}
printf("\n----- MESH TOPOLOGY -----\n\n");
for (int i = 1; i <= n; i++)
{
printf(" [PC-%d] ", i);
}
printf("\n\nConnections between computers:\n");
for (int i = 1; i <= n; i++)
{
for (int j = i + 1; j <= n; j++)
{
printf("PC-%d <----> PC-%d\n", i, j);
}
}
printf("\nIn Mesh Topology every computer is connected to every other
computer.\n");
return 0;
}

















