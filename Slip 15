Q2 - B write a c code to display mesh topology 
#include <stdio.h>
#define MAX 10
int main() {
    int n, i, j;
    int adj[MAX][MAX];
    printf("Enter number of nodes: ");
    scanf("%d", &n);
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            if(i == j)
                adj[i][j] = 0;  // No self-loop
            else
                adj[i][j] = 1;  // Connection exists
        }
    }
    printf("\nMesh Topology (Adjacency Matrix):\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            printf("%d ", adj[i][j]);
        }
        printf("\n");
    }
    return 0;
}

















