Q2 B- write a c program to implement the any data link layer framing method

#include <stdio.h>
#include <string.h>
int main() {
    char data[100], stuffed[200];
    int i, j = 0;
    printf("Enter data: ");
    scanf("%s", data);
    stuffed[j++] = 'F';
    for(i = 0; i < strlen(data); i++) {
        // If data contains flag or escape, add escape character
        if(data[i] == 'F' || data[i] == 'E') {
            stuffed[j++] = 'E';   // Escape character
        }
        stuffed[j++] = data[i];
    }
    stuffed[j++] = 'F';
    stuffed[j] = '\0';
    printf("\nStuffed Data: %s\n", stuffed);
    printf("\n=== Code Execution Successful ===\n");
    return 0;
}







