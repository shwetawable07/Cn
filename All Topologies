Program 2 - Write a program to displays a Ring Topology. 


#include <stdio.h>
int main()
{
int n;
printf("Enter number of computers in ring topology: ");
scanf("%d", &n);
if (n < 2)
{
printf("Ring topology requires at least 2 computers.\n");
return 0;
}
printf("\n----- RING TOPOLOGY -----\n\n");
for (int i = 1; i <= n; i++)
{
printf(" [PC-%d] ", i);
if (i != n)
printf("---");
}
printf("--- [PC-1]");
printf("\n\nAll computers are connected in a closed loop.\n");
return 0; 
}



Program 3 - Write a program to displays a Mesh Topology. 

#include <stdio.h>
int main()
{
int n;
printf("Enter number of computers in mesh topology: ");
scanf("%d", &n);
if (n < 2)
{
printf("Mesh topology requires at least 2 computers.\n");
return 0;
}
printf("\n----- MESH TOPOLOGY -----\n\n"); 
for (int i = 1; i <= n; i++)
{
printf(" [PC-%d] ", i);
}
printf("\n\nConnections between computers:\n");
for (int i = 1; i <= n; i++)
{
for (int j = i + 1; j <= n; j++)
{
printf("PC-%d <----> PC-%d\n", i, j);
}
}
printf("\nIn Mesh Topology every computer is connected to every other computer.\n");
return 0; 
}




Program 4 - Write a program to displays a Tree Topology. 

#include <stdio.h>
int main( )
{
int n;
printf("Enter number of computers in tree topology: ");
scanf("%d", &n);
if (n < 3)
{
printf("Tree topology requires at least 3 computers.\n");
return 0;
}
printf("\n----- TREE TOPOLOGY -----\n\n");
printf(" [ROOT]\n");
printf(" |\n");
printf(" -------------\n");
printf(" | |\n");
for(int i = 1; i <= n; i++)
{
printf(" [PC-%d] ", i);
if(i % 2 == 0)
printf(" | |\n");
printf("\n");
}
printf("\n\nHierarchical structure like a tree.\n"); 
return 0; 
}



