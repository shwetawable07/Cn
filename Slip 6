Q2 (B) – Option 1: Framing (Character Count Method)
#include <stdio.h>
#include <string.h>
int main() {
    char data[50];
    int len;
    printf("Enter data: ");
    scanf("%s", data);
    len = strlen(data);
    printf("Framed data: %d%s\n", len, data);
    return 0;
}
